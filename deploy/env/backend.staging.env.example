DATABASE_URL=postgresql://tasktime:replace-with-staging-db-password@postgres:5432/tasktime_staging?schema=public
SOURCE_DATABASE_URL=postgresql://readonly-user:replace-with-readonly-password@prod-host:5432/tasktime?schema=public
# SOURCE_DATABASE_URL is required by db:sync:prod-to-dev and should point to a read-only production/staging source.
JWT_SECRET=replace-with-staging-jwt-secret
JWT_REFRESH_SECRET=replace-with-staging-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://staging.tasktime.local
REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL_SECONDS=30
# Optional: if set, deploy will upsert the built-in MVP users with this password.
BOOTSTRAP_DEFAULT_PASSWORD=

# ===== Sprint 4: AI + Integrations =====
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret
TELEGRAM_WEBHOOK_URL=https://staging.tasktime.local/api/integrations/telegram/webhook
GITLAB_WEBHOOK_SECRET=replace-with-random-secret
