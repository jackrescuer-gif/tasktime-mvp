DATABASE_URL=postgresql://tasktime:replace-with-production-db-password@postgres:5432/tasktime?schema=public
JWT_SECRET=replace-with-production-jwt-secret
JWT_REFRESH_SECRET=replace-with-production-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://tasktime.example.com
REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL_SECONDS=30
# SOURCE_DATABASE_URL is intentionally omitted here. Prod-to-dev sync should run from the target dev/staging env file, not the production deploy env file.
# Optional: if set, deploy will upsert the built-in MVP users with this password.
BOOTSTRAP_DEFAULT_PASSWORD=

# ===== Sprint 4: AI + Integrations =====

# Claude API (required for AI estimate/decompose features)
ANTHROPIC_API_KEY=

# Telegram Bot (optional, notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret
TELEGRAM_WEBHOOK_URL=https://tasktime.example.com/api/integrations/telegram/webhook

# GitLab integration (optional, webhook auto-status updates)
GITLAB_WEBHOOK_SECRET=replace-with-random-secret
