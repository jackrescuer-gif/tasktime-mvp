DATABASE_URL=postgresql://tasktime:replace-with-production-db-password@postgres:5432/tasktime?schema=public
JWT_SECRET=replace-with-production-jwt-secret
JWT_REFRESH_SECRET=replace-with-production-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://tasktime.example.com
REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL_SECONDS=30
# Optional bootstrap. Keep disabled by default in production.
# Set BOOTSTRAP_ENABLED=true only for a deliberate one-time bootstrap.
BOOTSTRAP_DEFAULT_PASSWORD=
BOOTSTRAP_ENABLED=false
# Optional personal admin account created only during explicit bootstrap.
BOOTSTRAP_OWNER_ADMIN_EMAIL=
