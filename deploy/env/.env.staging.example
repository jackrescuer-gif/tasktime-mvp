COMPOSE_PROJECT_NAME=tasktime-staging
BACKEND_IMAGE=ghcr.io/your-org/tasktime-backend
WEB_IMAGE=ghcr.io/your-org/tasktime-web
IMAGE_TAG=main
WEB_HTTP_PORT=8080
POSTGRES_DB=tasktime_staging
POSTGRES_USER=tasktime
POSTGRES_PASSWORD=replace-with-staging-db-password
SOURCE_DATABASE_URL=postgresql://readonly-user:replace-with-readonly-password@prod-host:5432/tasktime?schema=public
# Required by db:sync:prod-to-dev. Use a read-only production/staging source.
