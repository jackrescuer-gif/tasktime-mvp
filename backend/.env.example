DATABASE_URL="postgresql://tasktime:tasktime@localhost:5432/tasktime?schema=public"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"
REDIS_URL="redis://localhost:6379"
REDIS_CACHE_TTL_SECONDS=30
# Optional local bootstrap for built-in users via `npm run db:bootstrap`
BOOTSTRAP_ENABLED="false"
BOOTSTRAP_DEFAULT_PASSWORD=""
BOOTSTRAP_OWNER_ADMIN_EMAIL=""
# GitLab webhook (optional): secret token from GitLab project webhook settings
# GITLAB_WEBHOOK_SECRET="your-secret-token"
# Optional: user id for pipeline comments (comments will be created as this user)
# GITLAB_SYSTEM_USER_ID="uuid-of-system-user"
