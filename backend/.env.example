# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=tasktime
PG_USER=postgres
PG_PASSWORD=your_password

# JWT (generate a random string, e.g. openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Server
PORT=3000

# Пиксель Офис: при создании задачи отправляется POST на этот URL (тело: source=tasktime, event=task.created, task={...})
# PIXEL_OFFICE_WEBHOOK_URL=https://your-pixel-office-api/tasktime-webhook
